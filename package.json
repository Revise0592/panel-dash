{
  "name": "panel",
  "version": "1.0.0",
  "description": "Self-hosted media & download monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.panel.dash",
    "productName": "Panel",
    "publish": {
      "provider": "github",
      "owner": "Revise0592",
      "repo": "panel-dash"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!*.md",
      "!screenshot/"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "tar.gz"],
      "icon": "assets/icon.png"
    }
  }
}
